# OAK Environment Configuration
# Copy to .env and customize for your environment

# Platform mode: dgx | mini | cloud
OAK_MODE=dgx

# Host paths — these must be absolute paths on the HOST machine
# (Docker bind mounts resolve on the host, not inside containers)
OAK_ROOT=/path/to/oak
OAK_WORKSPACE_BASE=/path/to/oak-workspaces

# Docker network name (auto-created by compose; format: {project}_{network})
OAK_NETWORK=oak_oak-net

# Models
CODER_MODEL=qwen3-coder
ANALYSIS_MODEL=glm-4.7
REASONING_MODEL=llama3.3:70b

# Anthropic API key (only needed for stall-detection escalation)
ANTHROPIC_API_KEY_REAL=

# Feature flags
META_AGENT_ENABLED=true
TELEMETRY_ENABLED=true
SKILL_EXTRACTION_ENABLED=true
JUDGE_REQUIRED=true

# Resource caps
MAX_AGENTS_PER_PROBLEM=10
MAX_CONCURRENT_PROBLEMS=3
MAX_HARNESS_CONTAINERS=20

# Daemon
OAK_DAEMON_POLL_INTERVAL=60
